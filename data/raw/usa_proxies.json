    "data_sources": {
        "energy_per_capita_GJ": "EIA Monthly Energy Review; BP Statistical Review; Smil (2017) historical estimates",
        "trade_volume_index": "World Bank WITS; BEA trade data; ratio of trade to GDP normalized to 2000 peak",
        "urbanization_rate": "US Census Bureau; UN World Urbanization Prospects",
        "rnd_spending_pct_gdp": "NSF Science & Engineering Indicators; OECD R&D statistics; AAAS historical series",
        "high_tech_export_share": "World Bank TCdata360; share of high-tech in manufactured exports",
        "manufacturing_output_index": "Federal Reserve Industrial Production Index (manufacturing) normalized to 1972 baseline",
        "top_1_percent_income_share": "Piketty & Saez (2003) updated series; World Inequality Database (WID.world)",
        "top_10_percent_wealth_share": "Federal Reserve DFA Survey of Consumer Finances; Saez & Zucman (2016, 2020); WID.world",
        "tax_regressivity_index": "IRS SOI Tax Stats; Piketty, Saez & Zucman (2018); effective tax rate ratio bottom 50% / top 1% normalized",
        "rent_sector_dominance": "BEA GDP by industry; share of FIRE + monopoly platform rents in corporate profits",
        "state_capture_index": "Gilens & Page (2014); V-Dem polyarchy index; Citizens United 2010 effect; lobbying / GDP ratio",
        "financialization_index": "Krippner (2005) metric; ratio financial sector profits to total corporate profits; financial assets / GDP",
        "external_debt_burden_export_index": "US Treasury TIC data; foreign holdings of US Treasuries / foreign GDP ratio; measure of debt burden successfully 'exported' to allies via currency agreements (Smithsonian 1971, Plaza 1985) and reserve accumulation by Japan/China/Europe",
        "public_infrastructure_share": "CBO Historical Budget Data; share of federal + state spending on infrastructure vs transfers to financial sector",
        "generalized_trust_proxy": "General Social Survey (GSS) trust question; Pew Research social trust surveys; ANES trust in government index",
        "social_mobility_index": "Chetty et al. (2017) Opportunity Atlas; intergenerational income elasticity; PSID panel data",
        "education_spending_pct_gdp": "NCES Digest of Education Statistics; OECD Education at a Glance; state + local + federal",
        "healthcare_spending_pct_gdp": "CMS National Health Expenditure Data; OECD Health Statistics",
        "union_density": "Bureau of Labor Statistics union membership; historical series from Troy & Sheflin (1985)"
    },
    "notes": {
        "period_1933_1971": "The 'Great Compression': Bretton Woods, Glass-Steagall, high marginal tax rates, strong unions produce low K, high C. US runs trade surpluses, builds domestic infrastructure, maintains gold convertibility. This is the baseline 'civilizational' attractor.",
        "mechanism_smithsonian_1971_1973": "Nixon Shock (Aug 1971): US closes gold window, imposes 10% import surcharge. December 1971 Smithsonian Agreement: dollar devalued from $35 to $38/oz, yen revalued from ¥360 to ¥308 (16.9% appreciation), D-mark revalued 13.6%. February 1973: dollar devalued again to $42.22/oz, yen floats up to ¥265. Total yen appreciation 1971-1973: ~36%. This forced revaluation exports US inflation to Japan and Germany, making their exports more expensive and reducing US real debt burden. Japan's export-led model is structurally broken; To offset, Japan undertakes massive domestic stimulus (Tanaka plan) and loose monetary policy, planting seeds of 1980s bubble. This is the first major 'external debt burden export' operation.",
        "mechanism_plaza_accord_1985": "G5 meeting at Plaza Hotel: US deliberately drives down dollar vs yen and D-mark. Yen appreciates from ¥240 to ¥120 over 1985-1988 (50%). Japan forced to undertake massive monetary easing to offset export drag, creating asset bubble (Nikkei peaks 1989, real estate peaks 1991). Bubble bursts, Japan enters 'lost decades'. Japanese institutional investors (MoF, postal savings, insurers) continue buying US Treasuries throughout, funding US deficits. Plaza Accord is the second major 'debt burden export' — US offloads adjustment cost onto Japan's financial system, creating permanent stagnation.",
        "mechanism_ussr_collapse_1991": "Third one-time extraction: ex-Soviet intellectual property, natural resources, and dollarization of post-Soviet space generate massive windfall. Russian brain drain supplies US tech sector. Oil/gas resources come under Western extraction terms. This creates the 'peace dividend' illusion that US K can rise without consequence.",
        "mechanism_china_treasury_accumulation_2000_2015": "China pegs yuan to dollar, accumulates $1T+ in Treasuries. Suppresses US interest rates, enables housing bubble and federal deficit expansion. Functionally identical to Japan's role in 1980s-1990s: export surplus recycled into US debt, suppressing domestic consumption in creditor country.",
