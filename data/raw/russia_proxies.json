    "data_sources": {
        "energy_per_capita_GJ": "Rosstat energy balance; BP Statistical Review; IEA Russia profile (2024)",
        "trade_volume_index": "World Bank WITS database; ratio of Russian trade to GDP, normalized to 2008 peak",
        "urbanization_rate": "Rosstat demographic yearbook; UN World Urbanization Prospects",
        "rnd_spending_pct_gdp": "UNESCO Science Report; HSE ISSEK indicators; Russia R&D spending as % GDP",
        "high_tech_export_share": "World Bank TCdata360; share of high-tech exports in manufactured exports",
        "top_1_percent_income_share": "World Inequality Database (WID.world); Novokmet, Piketty & Zucman (2018)",
        "top_10_percent_wealth_share": "World Inequality Database; Credit Suisse Global Wealth Report",
        "tax_regressivity_index": "Flat 13% PIT 2001-2020; 15% over 5M rubles from 2021; indirect tax share ~55% of budget; property tax negligible; high payroll tax regressivity",
        "rent_sector_dominance": "Rosstat GDP by sector; oil & gas 30-40% of budget 2000-2014, 50%+ from 2022; state corporate control via SOEs ~60% of GDP (IMF 2019)",
        "state_capture_index": "EBRD transition indicators; World Bank Governance Indicators; Transparency International CPI; V-Dem Polyarchy index",
        "public_infrastructure_share": "Rosstat; share of consolidated budget on public goods (roads, utilities, public transport) vs defense/security",
        "generalized_trust_proxy": "World Values Survey wave 7; Levada Center 'do you trust most people?' trend; ESS Russia data",
        "social_mobility_index": "HSE social mobility studies; World Bank 'Social Mobility in Russia' (2018); intergenerational income elasticity ~0.5",
        "education_spending_pct_gdp": "UNESCO Institute for Statistics; Rosstat; OECD Education at a Glance",
        "healthcare_spending_pct_gdp": "WHO Global Health Expenditure Database; Rosstat; Federal Treasury execution data"
    },
    "notes": {
        "period_2000_2018": "Recovery and stabilization: flat tax, oil rent, initial import substitution after 2014 sanctions. Rising K (state capture, rent concentration) offset by growing T (energy exports, consumption boom). C declines slowly as trust erodes.",
        "period_2018_2036_projection": "Accelerated degradation: pension reform + VAT hike (2018) mark shift to domestic extraction. SVO (2022) triggers self-sanctioning via technological isolation, forced import substitution with inferior domestic analogs, military Keynesianism. K rises sharply as war economy concentrates resources in state/military-industrial elite. T declines due to brain drain, technology embargo, degradation of civilian capital stock. C collapses as repression + atomization intensify.",
        "key_mechanisms": [
            "Pension reform (2018): extracted ~3% GDP from households, direct K increase",
            "VAT hike 18->20% (2019): regressive consumption tax, K++",
            "SVO self-sanctions: voluntary cutoff from Western tech stacks, equipment, components",
            "Import substitution: replacement of foreign tech with lower-quality domestic analogs reduces T productivity",
            "Excise growth: fuel, alcohol, tobacco excises rising faster than inflation -> regressive extraction",
            "Housing/utility tariff growth: above inflation annual increases in communal payments",
            "Brain drain: 500K-1M skilled workers emigrated 2022-2024",
            "Military spending: 6-8% GDP on defense/security diverts resources from civilian T and C"
        ]
    }
}